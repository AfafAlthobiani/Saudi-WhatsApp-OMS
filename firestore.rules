rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: merchants
    // Fields: id, store_name, credits, created_at
    //
    // Collection: products
    // Fields: merchant_id, name, price, stock, image_url
    //
    // Collection: orders
    // Fields: merchant_id, customer_name, customer_phone, city, district, total_amount, status, created_at
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isMerchantOwner(merchantId) {
      return isAuthenticated() && request.auth.uid == merchantId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "AFAFALTHOBIANI@gmail.com" && request.auth.token.email_verified == true));
    }

    // Domain Validators
    function isValidMerchant(data) {
      return data.keys().hasAll(['name', 'credits']) &&
             data.name is string && data.name.size() > 0 &&
             data.credits is number;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['merchant_id', 'name', 'price']) &&
             data.merchant_id is string &&
             data.name is string && data.name.size() > 0 &&
             data.price is number && data.price >= 0;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['merchant_id', 'customer_name', 'total_amount', 'status']) &&
             data.merchant_id is string &&
             data.customer_name is string && data.customer_name.size() > 0 &&
             data.total_amount is number && data.total_amount >= 0 &&
             data.status in ['pending', 'processing', 'shipped', 'delivered', 'cancelled'];
    }

    match /merchants/{merchantId} {
      allow read: if isAuthenticated() && (request.auth.uid == merchantId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == merchantId && isValidMerchant(request.resource.data);
      allow update: if isAuthenticated() && request.auth.uid == merchantId && isValidMerchant(request.resource.data);
    }

    match /products/{productId} {
      allow read: if true; // Publicly readable for customers
      allow create: if isAuthenticated() && request.resource.data.merchant_id == request.auth.uid && isValidProduct(request.resource.data);
      allow update: if isAuthenticated() && resource.data.merchant_id == request.auth.uid && isValidProduct(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.merchant_id == request.auth.uid;
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.merchant_id == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.merchant_id == request.auth.uid && isValidOrder(request.resource.data);
      allow update: if isAuthenticated() && resource.data.merchant_id == request.auth.uid && isValidOrder(request.resource.data);
      
      match /items/{itemId} {
        allow read: if isAuthenticated() && (get(/databases/$(database)/documents/orders/$(orderId)).data.merchant_id == request.auth.uid || isAdmin());
        allow write: if isAuthenticated() && get(/databases/$(database)/documents/orders/$(orderId)).data.merchant_id == request.auth.uid;
      }
    }
  }
}
